{
  "name": "dgidb-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler types && wrangler deploy",
    "dev": "wrangler types && wrangler dev --port 8797",
    "format": "biome format --write",
    "lint": "biome lint --diagnostic-level=error src/",
    "lint:fix": "biome lint --fix",
    "start": "wrangler types && wrangler dev",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@types/node": "^24.3.1",
    "typescript": "^5.5.2",
    "wrangler": "^4.2.0"
  },
  "dependencies": {
    "@bio-mcp/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.7.6",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.26.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
